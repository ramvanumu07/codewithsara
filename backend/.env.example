# Sara Backend - Environment Variables
# Copy this to .env and fill in your values.
# For Netlify/Vercel: add these in Project Settings → Environment Variables.

# === REQUIRED ===
# Get from Neon Console → your project → Connection details
DATABASE_URL=postgresql://user:password@host/database?sslmode=require

# Generate a random string (e.g. openssl rand -hex 32)
JWT_SECRET=your_jwt_secret_here

# === AI (required for chat) ===
# Get from console.groq.com → API keys
GROQ_API_KEY=your_groq_api_key_here

# === OPTIONAL ===
# When 1/true: session chat responses include `groqDebug` (system prompt + exact messages[] sent to Groq). Frontend logs to console. Do not enable in production.
DEBUG_GROQ_PAYLOAD=

PORT=5000
NODE_ENV=development
FRONTEND_URL=http://localhost:5173
BCRYPT_ROUNDS=12
# Rate limit: requests per minute per IP (default 20)
RATE_LIMIT_PER_MINUTE=20
# Legacy POST /api/auth/login-legacy (student_id). Ignored unless NODE_ENV=production — set true only if you still need old clients.
ENABLE_LEGACY_STUDENT_LOGIN=
REDIS_URL=
SENTRY_DSN=

# === Razorpay (checkout) ===
# Dashboard → Settings → API Keys (Key ID + Key Secret)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
# Optional fallback if no matching row in public.coupons: JSON map code → flat discount in rupees, e.g. {"WELCOME100":100}
CHECKOUT_COUPONS_JSON=
