# Sara Learning Platform - Frontend Environment Variables

# API Configuration (axios uses /api on this host). Jobs table uses the same origin without /api for /jobs-json and /jobs-csv.
# Local: http://localhost:5000 works via CORS, or leave unset to use Vite proxy paths /jobs-json (see vite.config.js).
# Netlify production: set to your Render app root, e.g. https://your-api.onrender.com
VITE_API_BASE_URL=http://localhost:5000

# Razorpay Checkout (publishable Key ID only — never put the secret here)
VITE_RAZORPAY_KEY_ID=

# Shown on checkout with Copy button (must exist in backend coupons or CHECKOUT_COUPONS_JSON)
VITE_CHECKOUT_PROMO_CODE=WELCOMESARA
VITE_APP_NAME=Sara Learning Platform
VITE_APP_VERSION=2.0.0

# Development
VITE_DEBUG=true

# Sentry (Optional - error tracking)
VITE_SENTRY_DSN=your_sentry_dsn_here

# Analytics (Optional)
VITE_GA_TRACKING_ID=your_google_analytics_id_here